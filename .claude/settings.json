{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "cleanupPeriodDays": 30,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "echo '🚀 Claude Code session started for tsc-files project'",
            "type": "command"
          },
          {
            "command": "git status --porcelain | wc -l | xargs echo 'Uncommitted files:'",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "echo '✅ Claude Code session ended - remember to commit your changes'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(npm install -g:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm add -g:*)",
      "Bash(pnpm publish:*)",
      "Bash(rm -rf :*)",
      "Bash(sudo :*)",
      "Bash(yarn global:*)",
      "Bash(yarn publish:*)",
      "Edit(node_modules/**)",
      "Read(.env*)",
      "Read(.ssh/**)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(secrets/**)",
      "Write(.env*)",
      "Write(.ssh/**)",
      "Write(*.key)",
      "Write(*.pem)",
      "Write(bun.lockb)",
      "Write(node_modules/**)",
      "Write(package-lock.json)",
      "Write(yarn.lock)"
    ]
  },
  "spinnerTipsEnabled": false
}
